# Copy this to .env and fill in real values before running docker-compose

# JWT
POSTONMYWALL_JWT_SECRET=CHANGE_ME_TO_A_256BIT_BASE64_SECRET

# AWS
SPRING_CLOUD_AWS_CREDENTIALS_ACCESS_KEY=YOUR_ACCESS_KEY
SPRING_CLOUD_AWS_CREDENTIALS_SECRET_KEY=YOUR_SECRET_KEY
POSTONMYWALL_S3_BUCKET=your-s3-bucket-name

# TikTok
SOCIAL_TIKTOK_CLIENT_KEY=
SOCIAL_TIKTOK_CLIENT_SECRET=

# Twitter / X
SOCIAL_TWITTER_API_KEY=
SOCIAL_TWITTER_API_SECRET=
SOCIAL_TWITTER_BEARER_TOKEN=

# Instagram
SOCIAL_INSTAGRAM_CLIENT_ID=
SOCIAL_INSTAGRAM_CLIENT_SECRET=

# YouTube
SOCIAL_YOUTUBE_CLIENT_ID=
SOCIAL_YOUTUBE_CLIENT_SECRET=
